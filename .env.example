# ─────────────────────────────────────────────────────────
# LONGEVA — Variables de entorno
# Copia este archivo como .env en desarrollo local
# En Vercel: Settings → Environment Variables
# ─────────────────────────────────────────────────────────

# ── PROVEEDOR DE IA ──────────────────────────────────────
# 'groq'      → Testing gratuito (Llama 3.3 70B, sin web search)
# 'anthropic' → Producción (Claude Sonnet 4 + web search real)
AI_PROVIDER=groq

# ── API KEYS ─────────────────────────────────────────────
# Groq (testing): https://console.groq.com → API Keys → Create
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (producción): https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── SEGURIDAD ─────────────────────────────────────────────
# En producción, reemplazar * con tu dominio exacto:
# ALLOWED_ORIGIN=https://longeva.app
ALLOWED_ORIGIN=*

# ── BASE DE DATOS DE MOLÉCULAS ────────────────────────────
# URL pública del JSON de moléculas (puede ser GitHub raw)
# Si está en /public/data/molecules.json, dejar vacío
MOLECULES_DB_URL=

# ── OPCIONES OPCIONALES ───────────────────────────────────
# Cache en segundos para respuestas IA (0 = sin cache)
AI_CACHE_TTL=3600

# ── STRIPE (PAYWALL STACK BUILDER) ─────────────────────────
# Clave secreta de Stripe (backend only)
STRIPE_SECRET_KEY=your_stripe_secret_key

# Opción A (recomendada): Price ID para crear Checkout Session dinámica
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxx

# Opción B (alternativa): Payment Link fijo (si usas esto, puede omitir STRIPE_PRICE_ID)
STRIPE_PAYMENT_LINK=

# URL base pública de tu app (sin barra final)
# Ej: https://longeva.app
APP_URL=http://localhost:3000
